# Discord bridge bot environment variables
# Copy this file to .env and fill in all values before starting the bot.
# The .env file must NEVER be committed to version control.

# Discord bot token (from https://discord.com/developers/applications → Bot → Token)
DISCORD_BOT_TOKEN=your-bot-token-here

# Full URL of your Discourse instance (no trailing slash)
DISCOURSE_URL=https://forum.christitus.com

# Shared HMAC secret — MUST match the value in Discourse:
#   Admin → Settings → community_integrations_discord_incoming_secret
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
HMAC_SECRET=change-me-to-a-long-random-string

# Discord channel IDs (right-click channel in Discord with Developer Mode on → Copy ID)
GENERAL_CHANNEL_ID=123456789012345678
SUPPORT_FORUM_ID=123456789012345679
